{
  "name": "agent-team-mcp",
  "version": "1.4.0",
  "description": "A reusable AI software development team built on MCP. 13 specialized agents collaborate through SQLite, orchestrated by a Project Manager.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-team-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/agents/*.md",
    "dist/CLAUDE.md",
    "!dist/**/__tests__/**"
  ],
  "scripts": {
    "build": "tsc && cp ../agents/*.md dist/agents/ && cp ../CLAUDE.md dist/",
    "prebuild": "mkdir -p dist/agents",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "software-development",
    "sqlite",
    "claude",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RichardLemmon/AgentTeam.git"
  },
  "license": "MIT",
  "author": "Richard Lemmon",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
